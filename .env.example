# ---------------------------------------------------------------------------
# Environment configuration for the Carbon Footprint Assistant.
#
# HOW TO USE:
#   1. Copy this file to a new file named exactly ".env" (same folder).
#   2. Paste your values after the "=" signs (no quotes, no spaces around "=").
#   3. Restart the server (python run.py). The values load automatically.
#
# The real ".env" file is git-ignored, so your keys are never committed.
# ---------------------------------------------------------------------------

# --- Optional AI brain (chatbot) -------------------------------------------
# Leave LLM_API_KEY blank to use the built-in carbon knowledge base only.
# Paste an OpenAI-compatible key to let Terra answer open-ended questions.
LLM_API_KEY=

# Defaults below work with OpenAI. Change them only if you use a different
# OpenAI-compatible provider/model.
LLM_API_URL=https://api.openai.com/v1/chat/completions
LLM_MODEL=gpt-4o-mini

# --- Server -----------------------------------------------------------------
# A long random string used to sign sessions. Generate your own for production.
SECRET_KEY=change-me-to-a-long-random-string

# Set to "production" on a live host; leave as "development" locally.
FLASK_ENV=development
